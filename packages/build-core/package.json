{
  "name": "@webmcp-dom/build-core",
  "version": "0.2.0",
  "description": "Compile data-mcp-* declarative DOM annotations into WebMCP registerTool calls",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./rollup": {
      "types": "./dist/rollup.d.ts",
      "import": "./dist/rollup.js"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "import": "./dist/webpack.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:bundlers": "node scripts/integration-smoke.mjs"
  },
  "keywords": [
    "webmcp",
    "mcp",
    "unplugin",
    "vite",
    "rollup",
    "webpack"
  ],
  "license": "MIT",
  "dependencies": {
    "@babel/generator": "^7.28.5",
    "@babel/parser": "^7.28.5",
    "@babel/traverse": "^7.28.5",
    "@babel/types": "^7.28.5",
    "fast-glob": "^3.3.3",
    "magic-string": "^0.30.21",
    "parse5": "^8.0.0",
    "picomatch": "^4.0.3",
    "unplugin": "^2.3.11"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^24.10.1",
    "@types/picomatch": "^4.0.2",
    "jsdom": "^27.2.0",
    "rollup": "^4.59.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  }
}
